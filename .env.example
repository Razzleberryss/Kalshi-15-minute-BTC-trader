# ===========================================================================
# Kalshi 15-Minute BTC Trader – Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ===========================================================================

# — Kalshi API Credentials —————————————————————————————————————————————
# Get these from: https://kalshi.com/profile/api-management
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshii_private_key.pem

# — Environment —————————————————————————————————————————————————————
# Use 'demo' for paper trading (free, no real money)
# Use 'prod' for live real-money trading
KALSHI_ENV=demo

# — Dry Run ————————————————————————————————————————————————————————
# true  = log trades to CSV but do NOT place real orders (safe default)
# false = place real orders on Kalshi
DRY_RUN=true

# — Risk Settings ———————————————————————————————————————————————
# Max dollars to risk per single trade
MAX_TRADE_DOLLARS=10
# Max number of open positions at any time
MAX_OPEN_POSITIONS=3
# Max total dollars deployed across all open positions
MAX_TOTAL_EXPOSURE=50
# Max realized loss per UTC day before blocking NEW entries (in cents)
MAX_DAILY_LOSS_CENTS=1000
# Max number of NEW entries per UTC day
MAX_DAILY_TRADES=20
# Allowed contract price range in cents (1–99)
MIN_CONTRACT_PRICE_CENTS=10
MAX_CONTRACT_PRICE_CENTS=90

# — Strategy Mode ——————————————————————————————————————————————————————
# fee_aware_model  – default momentum + fee-aware model strategy
# reddit_time_delay – time-delay + price-trigger stop-loss strategy
STRATEGY_MODE=fee_aware_model

# — Reddit Time-Delay Strategy Parameters ——————————————————————————————
# These settings are only used when STRATEGY_MODE=reddit_time_delay.
# Price (0.0–1.0) the winning side must reach to trigger an entry.
TRIGGER_POINT_PRICE=0.90
# Price (0.0–1.0) at which an open position is exited early (stop-loss).
EXIT_POINT_PRICE=0.40
# Only arm the strategy when this many minutes (or fewer) remain before expiry.
TRIGGER_MINUTE_REMAINING=14
# Maximum number of entries per 15-minute window (1 = one entry per window).
MAX_TRADES_PER_WINDOW=1

# — Strategy Settings ———————————————————————————————————————————————
# Kalshi BTC 15-minute series ticker.
# BTCZ is the correct live series for BTC up/down 15-min markets.
# Verify the exact value at: https://kalshi.com/markets/btcz
BTC_SERIES_TICKER=BTCZ
# yfinance BTC/USD symbol for spot price momentum
BTC_TICKER=BTC-USD
# Number of 1-min bars to look back for momentum calculation
MOMENTUM_LOOKBACK_BARS=5
# Minimum edge/confidence required to place a trade (0.0–1.0)
MIN_EDGE_THRESHOLD=0.05
# Exit controls (set 0 / false to disable)
STOP_LOSS_CENTS=20
TAKE_PROFIT_CENTS=30
SIGNAL_REVERSAL_EXIT=true

# — Orderbook Pricing ——————————————————————————————————————————————
# Use orderbook-derived prices instead of /markets API fields
USE_ORDERBOOK_PRICES=true
# Use WebSocket streaming for orderbook data (falls back to REST if unavailable)
# Default: true for demo/dry-run (safe to enable, always falls back to REST)
USE_WEBSOCKET_ORDERBOOK=true

# — Liquidity Filters ——————————————————————————————————————————————
# Maximum spread (in probability, 0.0-1.0) before skipping trade
# Example: 0.12 means skip if spread exceeds 12 cents
MAX_SPREAD=0.12
# Minimum orderbook depth (contracts) near mid price for YES/NO sides
MIN_YES_DEPTH=50
MIN_NO_DEPTH=50
# Depth band: how wide (in probability, 0.0-1.0) around mid to count depth
# Example: 0.05 means ±5 cents around mid
DEPTH_BAND=0.05

# — Fee-Aware Entry Settings ——————————————————————————————————————————
# Minimum probability mispricing (percentage points) required to trade.
# 0.10 = model must estimate YES probability at least 10 pp above/below market.
MIN_EDGE_PCT=0.10
# Forbidden price band: skip entries when YES price is in this range.
# Fees bite hardest near 0.50, so the default excludes the 0.30–0.70 region.
FORBIDDEN_PRICE_LOW=0.30
FORBIDDEN_PRICE_HIGH=0.70
# Minimum expected net value per contract after open+close fees (in dollars).
# 0.02 = require at least 2 cents of edge after fees.
MIN_EXPECTED_NET_PER_CONTRACT=0.02
# Position-sizing bounds (in contracts) for the edge-based dynamic sizer.
BASE_SIZE=1
MAX_SIZE=10
# At this mispricing level (and above) the sizer uses MAX_SIZE contracts.
MAX_EDGE_PCT=0.30
# Optional: Fixed position size in contracts (overrides dynamic BASE_SIZE/MAX_SIZE)
# Example: ORDER_SIZE_FP=5 means always trade exactly 5 contracts
#ORDER_SIZE_FP=

# — Bot Loop ——————————————————————————————————————————————————————
# How often the bot checks for a signal (seconds)
POLL_INTERVAL_SECONDS=60
# Seconds before contract expiry to trigger the expiry exit (default: 120)
EXPIRY_EXIT_SECONDS=120

# — API Client ——————————————————————————————————————————————————————
# Per-request timeout in seconds (default: 10)
REQUEST_TIMEOUT_SECONDS=10
# Max retry attempts for transient API errors; 0 disables retries (default: 3)
REQUEST_MAX_RETRIES=3

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# CSV file where every trade attempt is logged
TRADE_LOG_FILE=trades.csv
