# ===========================================================================
# Kalshi 15-Minute BTC Trader – Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ===========================================================================

# — Kalshi API Credentials —————————————————————————————————————————————
# Get these from: https://kalshi.com/profile/api-management
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# — Environment —————————————————————————————————————————————————————
# Use 'demo' for paper trading (free, no real money)
# Use 'prod' for live real-money trading
KALSHI_ENV=demo

# — Dry Run ————————————————————————————————————————————————————————
# true  = log trades to CSV but do NOT place real orders (safe default)
# false = place real orders on Kalshi
DRY_RUN=true

# — Risk Settings ———————————————————————————————————————————————
# Max dollars to risk per single trade
MAX_TRADE_DOLLARS=10
# Max number of open positions at any time
MAX_OPEN_POSITIONS=3
# Max total dollars deployed across all open positions
MAX_TOTAL_EXPOSURE=50
# Max realized loss per UTC day before blocking NEW entries (in cents)
MAX_DAILY_LOSS_CENTS=1000
# Max number of NEW entries per UTC day
MAX_DAILY_TRADES=20
# Allowed contract price range in cents (1–99)
MIN_CONTRACT_PRICE_CENTS=10
MAX_CONTRACT_PRICE_CENTS=90

# — Strategy Settings ———————————————————————————————————————————————
# Kalshi BTC 15-minute series ticker.
# BTCZ is the correct live series for BTC up/down 15-min markets.
# Verify the exact value at: https://kalshi.com/markets/btcz
BTC_SERIES_TICKER=BTCZ
# yfinance BTC/USD symbol for spot price momentum
BTC_TICKER=BTC-USD
# Number of 1-min bars to look back for momentum calculation
MOMENTUM_LOOKBACK_BARS=5
# Minimum edge/confidence required to place a trade (0.0–1.0)
MIN_EDGE_THRESHOLD=0.05
# Exit controls (set 0 / false to disable)
STOP_LOSS_CENTS=20
TAKE_PROFIT_CENTS=30
SIGNAL_REVERSAL_EXIT=true

# — Bot Loop ——————————————————————————————————————————————————————
# How often the bot checks for a signal (seconds)
POLL_INTERVAL_SECONDS=60

# — Logging & Output ———————————————————————————————————————————————
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# CSV file where every trade attempt is logged
TRADE_LOG_FILE=trades.csv
